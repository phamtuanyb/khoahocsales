{
  "name": "mkt-academy",
  "version": "0.1.0",
  "private": true,
  "description": "MKT Academy — Nền tảng đào tạo nhân sự game hóa cho Phần mềm MKT (MVP Sales)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run start:dev --workspace=@mkt-academy/api",
    "dev:web": "npm run dev --workspace=@mkt-academy/web",
    "build": "npm-run-all build:types build:api build:web",
    "build:types": "npm run build --workspace=@mkt-academy/types",
    "build:api": "npm run build --workspace=@mkt-academy/api",
    "build:web": "npm run build --workspace=@mkt-academy/web",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "npm run prisma:migrate --workspace=@mkt-academy/api",
    "db:seed": "npm run prisma:seed --workspace=@mkt-academy/api",
    "db:studio": "npm run prisma:studio --workspace=@mkt-academy/api"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
